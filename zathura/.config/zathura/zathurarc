set adjust-open "best-fit"
set selection-clipboard clipboard
# set page-padding 0
# set recolor-lightcolor "rgba(36, 40, 59, 0.6)"

set recolor-lightcolor "rgba(0, 0, 0, 0)"
set recolor-darkcolor "rgba(255, 255, 255, 1)"
map i recolor
set recolor true
set adjust-open "best"
set guioptions none
map <Shift+j> scroll down 10
map <Shift+k> scroll up 10
map j scroll down 1
map k scroll up 1

# map <mouse-8> navigate previous
# map <mouse-9> navigate next
